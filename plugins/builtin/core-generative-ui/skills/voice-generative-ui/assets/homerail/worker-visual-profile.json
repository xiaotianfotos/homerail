          { "id": "finding-one-text", "component": "Text", "text": { "path": "/actor_view/data/finding_one" }, "variant": "caption" },
          { "id": "finding-two", "component": "HrSection", "title": "发现 02", "children": ["finding-two-text"], "tone": { "path": "/actor_view/data/accent_tone" } },
          { "id": "finding-two-text", "component": "Text", "text": { "path": "/actor_view/data/finding_two" }, "variant": "caption" },
          { "id": "details", "component": "HrDisclosure", "title": "来源与证据边界", "children": ["source-one", "source-two"] },
          { "id": "source-one", "component": "Text", "text": { "path": "/actor_view/data/source_one" }, "variant": "caption" },
          { "id": "source-two", "component": "Text", "text": { "path": "/actor_view/data/source_two" }, "variant": "caption" }
        ]
      },
      "data_contract": {
        "source": { "input_port": "mission", "encoding": "value", "pointer": "" },
        "required_phases": ["started", "partial", "final"],
        "fields": [
          { "field": "title", "mode": "presentation", "value_schema": { "type": "string", "max_length": 64 } },
          { "field": "phase_text", "mode": "presentation", "value_schema": { "type": "string", "max_length": 32 } },
          { "field": "summary", "mode": "presentation", "value_schema": { "type": "string", "max_length": 120 } },
