{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "summary": { "type": "string", "maxLength": 4000 },
    "surface": { "type": "string", "enum": ["task", "execution", "result", "ambient"] },
    "importance": { "type": "string", "enum": ["critical", "primary", "secondary", "ambient"] },
    "density": { "type": "string", "enum": ["glance", "summary", "detail"] },
    "persistence": { "type": "string", "enum": ["turn", "session", "project"] },
    "content": { "$ref": "#/definitions/content" },
    "view": {
      "type": "object",
      "properties": {
        "view_version": { "const": 1 },
        "root": {
          "type": "object",
          "maxProperties": 128,
          "additionalProperties": true
        }
      },
      "required": ["view_version", "root"],
      "additionalProperties": false
    }
  },
  "required": ["id", "title", "surface", "importance", "density", "persistence", "content", "view"],
  "additionalProperties": false,
  "definitions": {
    "content": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "maxProperties": 128,
          "additionalProperties": true
        }
      },
      "required": ["data"],
      "additionalProperties": false
    }
  }
}
