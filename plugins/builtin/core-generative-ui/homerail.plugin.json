  "publisher": {
    "id": "com.homerail",
    "name": "HomeRail"
  },
  "license": "MIT",
  "compatibility": {
    "homerail": {
      "min": "0.1.0",
      "max_exclusive": "0.2.0"
    },
    "plugin_api": [1],
    "ui_ir": [1],
    "renderer_api": [1]
  },
  "capabilities": [
    {
      "id": "voice-generative-ui",
      "summary": "Maintain truthful, compact structured state on the voice surface.",
      "intents": [
        "remember evolving task requirements",
        "show confirmed task or execution state",
        "compose a dynamic structured interface",
        "动态生成界面"
      ],
      "tags": ["voice", "ui", "core"],
      "modalities": ["voice", "text", "touch", "gamepad"],
      "required_inputs": [],
      "skill": "voice-generative-ui",
      "tools": ["upsert_generated_view"],
      "workflows": [],
      "actions": []
    }
  ],
  "skills": [
    {
      "id": "voice-generative-ui",
      "path": "skills/voice-generative-ui/SKILL.md",
      "description": "Choose and maintain generated UI for a voice session without inventing execution state."
    }
  ],
