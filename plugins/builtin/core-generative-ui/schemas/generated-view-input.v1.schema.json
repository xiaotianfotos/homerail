{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Stable canvas Block id. For a new Block use a local id and HomeRail will namespace it. When Current HomeRail canvas state supplies an existing full id, reuse that exact id to update the selected Block."
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 200 },
    "summary": { "type": "string", "maxLength": 4000 },
    "surface": { "type": "string", "enum": ["task", "execution", "result", "ambient"] },
    "importance": { "type": "string", "enum": ["critical", "primary", "secondary", "ambient"] },
    "density": { "type": "string", "enum": ["glance", "summary", "detail"] },
    "canvas_size": {
      "type": "string",
      "enum": ["1x1", "1x2", "2x2", "3x3"],
      "description": "Canvas Block footprint. Only 1x1, 1x2, 2x2, and 3x3 are supported; horizontal 2x1 and 3x1 strips are forbidden."
    },
    "persistence": { "type": "string", "enum": ["turn", "session", "project"] },
    "content": { "$ref": "#/definitions/content" },
    "a2ui": {
      "type": "object",
      "properties": {
        "version": { "const": "v1.0" },
        "catalogId": { "const": "https://homerail.dev/a2ui/catalogs/core/v1" },
        "components": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "type": "object",
            "maxProperties": 32,
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              },
              "component": {
                "type": "string",
                "enum": [
                  "Text", "Image", "Icon", "Video", "AudioPlayer", "Row", "Column", "List",
                  "Card", "Tabs", "Modal", "Divider", "Button", "TextField", "CheckBox",
                  "ChoicePicker", "Slider", "DateTimeInput", "HrGrid", "HrGridItem", "HrSection",
                  "HrMetric", "HrStatusBadge", "HrProgress", "HrStep", "HrList", "HrTable",
                  "HrTimeline", "HrBarChart", "HrDag", "HrDisclosure", "HrLink", "HrArtifact", "HrIf"
                ]
              }
            },
            "required": ["id", "component"],
            "additionalProperties": true
          }
        },
        "surfaceProperties": {
          "type": "object",
          "properties": {
            "iconUrl": { "type": "string", "minLength": 1, "maxLength": 2048 },
            "agentDisplayName": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "additionalProperties": false
        }
      },
      "required": ["version", "catalogId", "components"],
      "additionalProperties": false
    }
  },
  "required": ["id", "title", "surface", "importance", "density", "canvas_size", "persistence", "content", "a2ui"],
  "additionalProperties": false,
  "definitions": {
    "content": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "maxProperties": 128,
          "additionalProperties": true
        }
      },
      "required": ["data"],
      "additionalProperties": false
    }
  }
}
