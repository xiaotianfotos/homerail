VITE_HOMERAIL_MANAGER_PORT=19191
# Text mode is temporarily disabled by default. Set to 1 only when restoring
# the text Agent shell for local debugging.
VITE_HOMERAIL_ENABLE_TEXT_MODE=0
# Dev-only: show a top-bar button next to the gamepad icon that opens onboarding.
VITE_HOMERAIL_DEV_ONBOARDING_ENTRY=0
# Dev-only: replace legacy Voice cards with the read-only, non-authoritative
# Generative UI shadow projection. Requires Manager generative_ui_mode=shadow.
VITE_HOMERAIL_GENERATIVE_UI_SHADOW_PREVIEW=0
# Optional override. If omitted, Agent UI derives Manager API from the browser host.
VITE_API_BASE_URL=http://localhost:19191
