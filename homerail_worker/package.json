{
  "name": "homerail-worker",
  "version": "0.1.0",
  "private": true,
  "description": "HomeRail TypeScript Worker runtime for Claude Agent SDK and compatible agent backends.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "postinstall": "cd ../homerail_protocol && npm ci",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.209",
    "@moonshot-ai/kimi-agent-sdk": "^0.1.8",
    "@moonshot-ai/kimi-code": "^0.22.3",
    "homerail-protocol": "file:../homerail_protocol",
    "ws": "^8.18.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
