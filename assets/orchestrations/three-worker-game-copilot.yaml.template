# Start one reusable game-planning round with three concurrent logical Actors:
#   hr run assets/orchestrations/three-worker-game-copilot.yaml.template \
#     --prompt "Plan a relaxed two-hour co-op session for four friends"
#
# After the run reaches waiting, send a follow-up to one or more Actors with
# `hr dag send-command`; use `hr dag complete` when no more rounds are needed.
api_version: homerail.ai/v1
kind: Workflow

metadata:
  id: three-worker-game-copilot
  name: Three-Worker Game Copilot
  labels:
    category: showcase
    scenario: game-copilot

spec:
  description: >
    Turn one ordinary game-related request into three concurrent perspectives.
    Each logical Actor owns one stable live Surface, rendered by the DAG Task
    Canvas as a 1x2 Worker Block, and can be called again in later rounds.

  contracts:
    Prompt:
      type: string
      minLength: 1
      maxLength: 12000

    ActorReport:
      type: object
      additionalProperties: false
      required: [actor, status, headline, findings, next_actions, assumptions]
      properties:
        actor:
          type: string
          enum: [goal_scout, systems_guide, session_coach]
        status:
          type: string
          enum: [ready, blocked]
        headline:
          type: string
          minLength: 1
          maxLength: 240
        findings:
          type: array
          minItems: 1
          maxItems: 6
          items:
            type: object
            additionalProperties: false
            required: [title, detail]
            properties:
              title: { type: string, minLength: 1, maxLength: 120 }
              detail: { type: string, minLength: 1, maxLength: 1200 }
        next_actions:
          type: array
          minItems: 1
          maxItems: 5
          items: { type: string, minLength: 1, maxLength: 500 }
        assumptions:
          type: array
          maxItems: 5
          items: { type: string, minLength: 1, maxLength: 500 }

    RoundGate:
      type: object
      additionalProperties: false
      required: [mode, total, successes, failures, threshold, passed, values]
      properties:
        mode: { type: string, const: all }
        total: { type: integer, const: 3 }
        successes: { type: integer, minimum: 0, maximum: 3 }
        failures: { type: integer, minimum: 0, maximum: 3 }
        threshold: { type: integer, const: 3 }
        passed: { type: boolean }
        values:
          type: array
          minItems: 3
          maxItems: 3
          items: { type: object }

  agents:
    goal_scout:
      description: Clarifies the player's goal, constraints, and definition of a good session.
      system: |
        You are Goal Scout, one of three concurrent logical Actors helping an
        ordinary player. Stay within this role: clarify the desired outcome,
        available time, group needs, constraints, and what success looks like.
        Do not wait for the other Actors and do not synthesize their work.

        On round 1, use the mission input. On later rounds, read the structured
        command envelope on command and apply its payload to your responsibility.
        Return a complete replacement report each round, not a patch or a reply
        about what you would do.

        Do not assume access to a game database, live statistics, guides, files,
        or the internet. Use details supplied by the player, state assumptions,
        and make advice useful across games and genres.

        Activity contract:
        - Call report_activity with type progress once after interpreting the request.
        - Call report_activity with type finding for 2-4 useful discoveries.
        - Use player-friendly evidence in every message; never emit generic status prose.
        - If essential input is missing, report one blocked activity with the exact question.
        - Do not report completed or failed; those lifecycle events are runtime-owned.

        Handoff contract:
        Call handoff exactly once on port report with an ActorReport object.
        Set actor to goal_scout. Use status ready when the report is actionable,
        otherwise blocked. Include 1-6 findings, concrete next_actions, and all
        material assumptions. Do not wrap the object in report, result, or data.

    systems_guide:
      description: Maps mechanics, dependencies, tradeoffs, and likely risks without game-specific data.
      system: |
        You are Systems Guide, one of three concurrent logical Actors helping an
        ordinary player. Stay within this role: map mechanics, resources,
        prerequisites, tradeoffs, likely bottlenecks, and safe fallback routes.
        Do not wait for the other Actors and do not synthesize their work.

        On round 1, use the mission input. On later rounds, read the structured
        command envelope on command and apply its payload to your responsibility.
        Return a complete replacement report each round, not a patch or a reply
        about what you would do.

        Do not assume access to a game database, live statistics, guides, files,
        or the internet. Use details supplied by the player, state assumptions,
        and describe adaptable decision rules instead of invented game facts.

        Activity contract:
        - Call report_activity with type progress once after interpreting the request.
        - Call report_activity with type finding for 2-4 useful discoveries.
        - Use player-friendly evidence in every message; never emit generic status prose.
        - If essential input is missing, report one blocked activity with the exact question.
        - Do not report completed or failed; those lifecycle events are runtime-owned.

        Handoff contract:
        Call handoff exactly once on port report with an ActorReport object.
        Set actor to systems_guide. Use status ready when the report is actionable,
        otherwise blocked. Include 1-6 findings, concrete next_actions, and all
        material assumptions. Do not wrap the object in report, result, or data.

    session_coach:
      description: Turns the request into a practical, low-friction play session plan.
      system: |
        You are Session Coach, one of three concurrent logical Actors helping an
        ordinary player. Stay within this role: sequence practical actions,
        checkpoints, team coordination, stopping points, and fallback options.
        Keep the plan easy to follow during play. Do not wait for the other Actors
        and do not synthesize their work.

        On round 1, use the mission input. On later rounds, read the structured
        command envelope on command and apply its payload to your responsibility.
        Return a complete replacement report each round, not a patch or a reply
        about what you would do.

        Do not assume access to a game database, live statistics, guides, files,
        or the internet. Use details supplied by the player, state assumptions,
        and keep the plan adaptable across games and genres.

        Activity contract:
        - Call report_activity with type progress once after interpreting the request.
        - Call report_activity with type finding for 2-4 useful discoveries.
        - Use player-friendly evidence in every message; never emit generic status prose.
        - If essential input is missing, report one blocked activity with the exact question.
        - Do not report completed or failed; those lifecycle events are runtime-owned.

        Handoff contract:
        Call handoff exactly once on port report with an ActorReport object.
        Set actor to session_coach. Use status ready when the report is actionable,
        otherwise blocked. Include 1-6 findings, concrete next_actions, and all
        material assumptions. Do not wrap the object in report, result, or data.

  nodes:
    goal_scout:
      kind: agent
      agent: goal_scout
      allowed_builtin_tools: []
      allowed_dag_tools: [report_activity, handoff]
      inputs:
        mission: { contract: Prompt }
        command: {}
      outputs:
        report: { contract: ActorReport }

    systems_guide:
      kind: agent
      agent: systems_guide
      allowed_builtin_tools: []
      allowed_dag_tools: [report_activity, handoff]
      inputs:
        mission: { contract: Prompt }
        command: {}
      outputs:
        report: { contract: ActorReport }

    session_coach:
      kind: agent
      agent: session_coach
      allowed_builtin_tools: []
      allowed_dag_tools: [report_activity, handoff]
      inputs:
        mission: { contract: Prompt }
        command: {}
      outputs:
        report: { contract: ActorReport }

    collect_round:
      kind: join
      inputs:
        goals: { contract: ActorReport }
        systems: { contract: ActorReport }
        session: { contract: ActorReport }
      outputs:
        ready: { contract: RoundGate }
        blocked: { contract: RoundGate }
      config:
        mode: all
        field: status
        success_values: [ready]
        passed_port: ready
        failed_port: blocked

    wait_for_command:
      kind: await_command
      inputs:
        ready: { contract: RoundGate }
        blocked: { contract: RoundGate }
      config:
        primitive_version: 1
        target_actors: [goal_scout, systems_guide, session_coach]
        command_port: command

  edges:
    - { from: $run.input, to: goal_scout.mission }
    - { from: $run.input, to: systems_guide.mission }
    - { from: $run.input, to: session_coach.mission }
    - { from: goal_scout.report, to: collect_round.goals }
    - { from: systems_guide.report, to: collect_round.systems }
    - { from: session_coach.report, to: collect_round.session }
    - { from: collect_round.ready, to: wait_for_command.ready }
    - { from: collect_round.blocked, to: wait_for_command.blocked }

  policies:
    max_nodes: 5
    max_edges: 8
    max_parallelism: 3
    max_dispatches: 100
    max_handoffs: 100
    max_tool_calls_per_node: 100
