  "tools": [
    {
      "id": "upsert_generated_view",
      "description": "Create or replace a HomeRail A2UI Block. Reuse its stable id. Choose canvas_size 1x1, 1x2, 2x2, or 3x3. Use HrTable or HrList for long collections, HrLink for HTTP(S) sources, and at most 3 HrGrid columns.",
      "exposure": ["agent"],
      "input_schema": "generated-view-input-v1",
      "output_schema": "generated-view-content-v1",
      "effect": "write",
      "permissions": [],
      "confirmation": "never",
      "handler": {
        "type": "projection",
        "file": "ui/projectors/generated-view.v1.json"
      }
    }
  ],
