{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "width": {
      "type": "integer",
      "minimum": 16,
      "maximum": 640
    },
    "height": {
      "type": "integer",
      "minimum": 16,
      "maximum": 640
    },
    "style": {
      "type": "string",
      "enum": ["cinematic", "editorial", "minimal"]
    }
  },
  "required": ["prompt", "width", "height", "style"],
  "additionalProperties": false
}
